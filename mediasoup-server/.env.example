# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Mediasoup Network ───────────────────────────────────────────
# Public IP of your VPS (used as announcedIp for WebRTC)
MEDIASOUP_ANNOUNCED_IP=YOUR_VPS_PUBLIC_IP

# UDP/TCP port range for WebRTC media
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999

# ── Auth ────────────────────────────────────────────────────────
# Same JWT secret as your FastAPI backend
JWT_SECRET=your_jwt_secret_here

# URL of your FastAPI backend (to verify tokens)
BACKEND_API_URL=http://localhost:8000

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGIN=https://smartchatx.alokkumarsahu.in
