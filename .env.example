# ─── SmartChat X — Environment Variables ─────────────
# Copy this file to .env and fill in your values

# Backend Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# TCP Socket Server
TCP_HOST=127.0.0.1
TCP_PORT=9000

# UDP Socket Server
UDP_HOST=127.0.0.1
UDP_PORT=9001

# WebSocket Bridge
WS_HOST=127.0.0.1
WS_PORT=8765

# AI Configuration — Groq LLM (Free tier: groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Security
SECRET_KEY=change-this-to-a-random-secret
ENCRYPTION_KEY=change-this-key

# Logging
LOG_LEVEL=INFO
